# =============================================================================
# APOST — Environment Variables Template
# Copy this file to .env and adjust values as needed.
#
# API keys are NOT set here. Each user enters their own API key directly
# in the APOST UI. It is sent per-request and never stored on the server.
# =============================================================================

# Enable verbose debug output (true/false)
DEBUG=false

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,http://127.0.0.1:5173

# Token budgets per operation (increase if you get truncated responses)
MAX_TOKENS_GAP_ANALYSIS=1500
MAX_TOKENS_OPTIMIZATION=4096
MAX_TOKENS_CHAT=2048
