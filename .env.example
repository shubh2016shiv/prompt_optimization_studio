# =============================================================================
# APOST - Environment Variables Template
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider API Keys (at least one required)
# -----------------------------------------------------------------------------

# Anthropic API Key (recommended - used for optimization)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI API Key (optional)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Google AI Studio API Key (optional)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# Enable debug mode (true/false)
DEBUG=false

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# Optimizer Settings
# -----------------------------------------------------------------------------

# Model used internally by APOST for gap analysis and optimization
OPTIMIZER_MODEL=claude-sonnet-4-20250514

# Token limits for different operations
MAX_TOKENS_GAP_ANALYSIS=1500
MAX_TOKENS_OPTIMIZATION=4096
MAX_TOKENS_CHAT=2048
