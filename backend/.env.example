# =============================================================================
# APOST Backend — Environment Variables
# Copy this file to .env and adjust values as needed.
#
# API keys are NOT set here. Users enter their own key in the UI,
# which is sent per-request and never stored on the server.
# =============================================================================

# Enable verbose FastAPI/Uvicorn output (true in dev, false in prod)
DEBUG=false

# Comma-separated list of allowed CORS origins
# Add http://localhost:5173 for local Vite dev server
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Token budgets per operation (increase if you get truncated responses)
MAX_TOKENS_GAP_ANALYSIS=1500
MAX_TOKENS_OPTIMIZATION=4096
MAX_TOKENS_CHAT=2048

# -----------------------------------------------------------------------------
# Prompt optimization runtime settings (optional overrides)
# -----------------------------------------------------------------------------
# OPTIMIZATION_LLM_SUB_TASK_PROVIDER=openai
# OPTIMIZATION_MAX_TOKENS_COMPONENT_EXTRACTION=2048
# OPTIMIZATION_TEXTGRAD_DEFAULT_ITERATION_COUNT=3
# OPTIMIZATION_OPRO_DEFAULT_ITERATION_COUNT=3
# OPTIMIZATION_OPRO_CANDIDATES_PER_ITERATION=2
# OPTIMIZATION_CORE_MINIMUM_REPETITION_COUNT=2
# OPTIMIZATION_CORE_MAXIMUM_REPETITION_COUNT=5
# OPTIMIZATION_PROVIDER_FORMATTING_DEFAULT_PROVIDER=openai
# OPTIMIZATION_SYSTEM_PROMPT_FOR_JSON_EXTRACTION="You are a precision text parser..."
# For dictionary-style settings, provide JSON values if overriding, for example:
# OPTIMIZATION_PREFILL_SUGGESTION_BY_TASK_TYPE={"extraction":"{","analysis":"## "}
